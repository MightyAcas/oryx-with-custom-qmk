// Scissoring reduction

AK(GV, KC_G, KC_V, false, KC_R)   // GV produces GR   ... inroll
AK(GR, KC_G, KC_R, false, KC_V)   // GR produces GV

AK(QO, KC_Q, KC_O, true, KC_BSPC, KC_Y)   // QO produces YO
  
// SFB reduction
AK(LJ, KC_L, KC_J, false, KC_Y)   // LJ produces LY   ... outroll
AK(LY, KC_L, KC_Y, false, KC_J)   // LY produces LJ

AK(NR, KC_N, KC_R, false, KC_Y)   // NR produces NY   ... alternation
AK(NY, KC_N, KC_Y, false, KC_R)   // NY produces NR   ... "anyway" and "anywhere" sucks now but besides that this is the best i can prob do.

AK(NH, KC_N, KC_H, false, KC_QUOTE)   // NH produces N'   ... alternation
AK(NQ, KC_N, KC_QUOTE, false, KC_H)   // N' produces NH

AK(NB, KC_N, KC_B, false, KC_L)   // NB produces NL   ... alternation
AK(NL, KC_N, KC_L, false, KC_B)   // NL produces NB

AK(WC, KC_W, KC_C, false, KC_R)   // WC produces WR   ... inroll
AK(WR, KC_W, KC_R, false, KC_C)   // WR produces WC

// Lateral stretch reduction & redirect
AK(MC, KC_M, KC_C, false, KC_B)   // MC produces MB   ... outroll
AK(MB, KC_M, KC_B, false, KC_C)   // MB produces MC

AK(HN, KC_H, KC_N, false, KC_T)   // HN produces HT   ... alternation
AK(HT, KC_H, KC_T, false, KC_N)   // HT produces HN   ... "ght" can be a slow sequence at times

